# Anthropic
ANTHROPIC_API_KEY=your-key-here

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nyx
POSTGRES_USER=nyx
POSTGRES_PASSWORD=change-me

# Telegram
TELEGRAM_BOT_TOKEN=your-token-here
TELEGRAM_ALLOWED_CHAT_ID=your-chat-id

# Webapp
WEBAPP_PORT=3000

# Logging
LOG_LEVEL=info

# Paths (container paths)
HOME_DIR=/home/nyx
SIGNALS_DIR=/app/signals
LOGS_DIR=/app/logs
